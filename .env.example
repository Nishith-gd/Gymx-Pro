# ============================================================
# GymX Pro — environment variables reference
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── Flask core ──────────────────────────────────────────────
FLASK_APP=app
# Set to 1 only for local development; must be 0 (or unset) in production.
FLASK_DEBUG=0

# Generate a strong key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-real-secret-key

# ── Database ─────────────────────────────────────────────────
# SQLite (development default — created automatically):
DATABASE_URL=sqlite:///gymx_pro.db

# MySQL / MariaDB (production):
# DATABASE_URL=mysql+pymysql://gymx_user:strongpassword@localhost:3306/gymx_pro

# PostgreSQL (alternative):
# DATABASE_URL=postgresql+psycopg2://gymx_user:strongpassword@localhost:5432/gymx_pro

# ── HTTPS / Security ────────────────────────────────────────
# Set to 1 when the app is served over HTTPS (enables HSTS + HTTPS redirect).
FORCE_HTTPS=0

# ── Gunicorn (production only) ───────────────────────────────
PORT=8000
# Defaults to (2 × CPU cores) + 1 if not set.
# WEB_CONCURRENCY=5
LOG_LEVEL=info
